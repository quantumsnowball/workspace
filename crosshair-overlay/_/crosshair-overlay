#!/bin/sh

# Define the absolute path
SCRIPT="$XDG_CONFIG_HOME/workspace/crosshair-overlay/crosshair-overlay.py"

# pkill -0 just checks if a process exists without killing it
if pkill -0 -f "$SCRIPT" 2>/dev/null; then
    pkill -f "$SCRIPT"
    printf "${RED}Crosshair Overlay DISABLED${RESET}\n"
else
    # Launch and disown so it stays alive after terminal closes
    "$SCRIPT" & disown
    printf "${YELLOW}Crosshair Overlay ENABLED${RESET}\n"
fi
