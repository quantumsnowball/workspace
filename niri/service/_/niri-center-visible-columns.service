[Unit]
Description=Niri Center Visible Columns
After=graphical-session.target

[Service]
Type=exec
ExecStart=%h/.config/workspace/niri/service/center-visible-columns.py
Restart=always
RestartSec=1
# Ensures logs show up immediately
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=graphical-session.target
