[Unit]
Description=Kanata Purifier
After=graphical-session.target
BindsTo=kanata.service
After=kanata.service

[Service]
Type=exec
# Replace with absolute paths
ExecStart=uv tool run evdev-purify keyboard kanata
Restart=always
RestartSec=1
# Ensures logs show up immediately
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=graphical-session.target
