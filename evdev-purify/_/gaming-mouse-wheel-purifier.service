[Unit]
Description=Gaming Mouse Wheel Purifier
After=graphical-session.target

[Service]
Type=exec
# Replace with absolute paths
ExecStart=uv tool run evdev-purify mouse-wheel "WLS.Ltd Gaming TouchPad Mouse"

Restart=always
RestartSec=1
# Ensures logs show up immediately
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=graphical-session.target
